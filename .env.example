# Backend Environment Variables
# Copy this file to backend/.env and fill with your values

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
# For MongoDB Atlas (cloud):
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/

# Database Name
DB_NAME=barcode_scanner

# CORS Origins (your domain)
CORS_ORIGINS=https://barras.facore.cloud

# ==========================================
# Frontend Environment Variables
# Copy this file to frontend/.env and fill with your values

# Backend URL (for API calls)
REACT_APP_BACKEND_URL=https://barras.facore.cloud

# WebSocket Port (for development)
WDS_SOCKET_PORT=443

# Health Check (optional)
ENABLE_HEALTH_CHECK=false
